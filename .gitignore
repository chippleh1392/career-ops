# Personal assets (never commit — e.g. resume PDFs; stays local with the project)
private/

# Personal data (user fills these)
cv.md
article-digest.md
data/applications.md
data/tracker-events.jsonl
data/pipeline.md
data/scan-history.tsv
data/market/*
!data/market/.gitkeep
reports/*.md
!reports/.gitkeep
# Interview-prep deep dives that should stay local even within ignored reports.
reports/domaine-*.md
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
batch/tracker-additions/merged/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# Playwright-captured full hydrated DOM (large; optional local only)
interview-prep/snapshots/

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard

# Local secrets (dotenv / env files — never commit)
.env
.env.local
.env.*.local
